# Environment Configuration - FuelPay
# Copy this file to .env and fill in actual values

# Environment
ENV=development

# API Configuration
API_URL=https://api.dev.fuelpay.app/v1

# Razorpay Keys (from Razorpay Dashboard)
RAZORPAY_KEY_ID=rzp_test_xxxxx
RAZORPAY_KEY_SECRET=xxxxx

# Google Maps API Key
MAPS_API_KEY=xxxxx

# Firebase Configuration
FIREBASE_PROJECT_ID=fuelpay-dev
FIREBASE_API_KEY=xxxxx
FIREBASE_AUTH_DOMAIN=fuelpay-dev.firebaseapp.com
FIREBASE_STORAGE_BUCKET=fuelpay-dev.appspot.com
FIREBASE_MESSAGING_SENDER_ID=xxxxx

# Feature Flags
ENABLE_ANALYTICS=true
ENABLE_CRASH_REPORTING=false
ENABLE_REMOTE_CONFIG=false

# Device Configuration
GEOFENCE_RADIUS_METERS=100
MAX_RETRY_COUNT=3
API_TIMEOUT_SECONDS=30
